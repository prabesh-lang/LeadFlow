{
  "name": "web",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev -H localhost --webpack",
    "build": "next build --webpack",
    "postbuild": "node scripts/ensure-database.mjs",
    "start": "node scripts/railway-db-guard.mjs && node scripts/ensure-database.mjs && node scripts/auto-bootstrap-railway.mjs && next start",
    "lint": "eslint . --max-warnings 0",
    "typecheck": "tsc --noEmit",
    "postinstall": "node scripts/ensure-xlsx-for-turbopack.mjs",
    "db:seed": "tsx database/seed.ts",
    "db:seed:bootstrap": "tsx database/seed-bootstrap.ts"
  },
  "engines": {
    "node": ">=20.9.0"
  },
  "dependencies": {
    "@supabase/ssr": "^0.7.0",
    "@supabase/supabase-js": "^2.49.8",
    "@tailwindcss/postcss": "4.2.2",
    "jspdf": "^4.2.1",
    "jspdf-autotable": "^5.0.7",
    "libphonenumber-js": "^1.12.40",
    "next": "16.2.1",
    "pg": "^8.13.1",
    "rate-limiter-flexible": "^11.0.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-phone-number-input": "^3.4.16",
    "tailwindcss": "4.2.2",
    "xlsx": "^0.18.5",
    "zod": "^4.3.6",
    "tsx": "^4.21.0"
  },
  "optionalDependencies": {
    "@tailwindcss/oxide-linux-arm64-gnu": "4.2.2",
    "@tailwindcss/oxide-linux-arm64-musl": "4.2.2",
    "@tailwindcss/oxide-linux-x64-gnu": "4.2.2",
    "@tailwindcss/oxide-linux-x64-musl": "4.2.2",
    "lightningcss-linux-arm64-gnu": "1.32.0",
    "lightningcss-linux-arm64-musl": "1.32.0",
    "lightningcss-linux-x64-gnu": "1.32.0",
    "lightningcss-linux-x64-musl": "1.32.0"
  },
  "devDependencies": {
    "@types/node": "^20",
    "@types/pg": "^8.11.10",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.1",
    "typescript": "^5"
  }
}
