# Copy to `.env` in this folder (`web/`). Paths are relative to `web/` when running Next/Prisma.
#
# Production: use your Supabase Postgres connection string for DATABASE_URL (often pooled, port 6543).
# Do not use file: SQLite for multi-instance serverless — use PostgreSQL. Set all Supabase keys in the host dashboard.
# Migrations in `prisma/migrations/` are SQLite. Use `npm run db:migrate:deploy` only when `DATABASE_URL` matches
# `provider` in `prisma/schema.prisma` (SQLite). For PostgreSQL/Supabase, apply schema using your agreed process
# (e.g. Prisma PostgreSQL datasource + new migrations, or SQL from `schema.postgresql.prisma`), not the SQLite files.

# --- Database (Prisma) ---
# Local: path is relative to this folder (web/). File lives at web/prisma/dev.db
DATABASE_URL="file:./prisma/dev.db"
#
# Railway / Docker (SQLite single container): set the same relative URL, or an absolute path on a
# writable volume, e.g. DATABASE_URL="file:/data/leadflow.db". The start script creates parent
# dirs and runs prisma migrate deploy. For production at scale, use Supabase Postgres instead.

# --- Supabase (Dashboard → Project Settings → API) ---
NEXT_PUBLIC_SUPABASE_URL="https://your-project-ref.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="your-supabase-anon-key"
SUPABASE_SERVICE_ROLE_KEY="your-supabase-service-role-key"

# Cron (GET /api/cron/sweep-overdue with header x-cron-secret). Generate: openssl rand -hex 32
CRON_SECRET=

# Excel import row cap (optional; default 1000, capped in code)
EXCEL_MAX_ROWS=1000
