# Copy to `.env` in this folder (`web/`).
#
# Primary database is PostgreSQL (Supabase). Create a project at https://supabase.com,
# then Project Settings → Database → copy the connection string (URI).
# Prefer the "Session mode" or direct connection (port 5432) for Prisma migrate deploy.
# Transaction pooler (port 6543) can work for the app runtime; if migrations fail, use 5432 for DATABASE_URL during deploy.

# --- Database (Prisma → Supabase Postgres) ---
# Append ?sslmode=require (Supabase expects SSL). Example:
# DATABASE_URL="postgresql://postgres.[PASSWORD]@db.[REF].supabase.co:5432/postgres?sslmode=require"
DATABASE_URL="postgresql://postgres.[YOUR-PASSWORD]@db.[YOUR-PROJECT-REF].supabase.co:5432/postgres?sslmode=require"
#
# P1001 "Can't reach database server" from your laptop usually means:
# - Supabase project is paused — open dashboard and Resume the project.
# - Network blocks outbound port 5432 (corporate/school Wi‑Fi) — try another network or phone hotspot.
# - Rare: direct host db.*.supabase.co:5432 is IPv6-only on some setups — use the pooler URI from
#   Database → Connection string → "Session pooler" or see Supabase IPv4 / pooler docs.
#
# If your laptop always gets P1001 but Railway deploy works, run migrate + seed on Railway (same DB as prod).
# Avoid global npm install (EACCES on /usr/local): use npx — from your repo:
#   cd web && npx @railway/cli login && npx @railway/cli link
#   npx @railway/cli run npx prisma migrate deploy
#   npx @railway/cli run npx prisma db seed
# (Uses DATABASE_URL from the linked Railway service.)
#
# After changing from SQLite: run `npx prisma migrate deploy` in `web/`, then `npx prisma db seed` if you want demo data.
# To move old SQLite rows into Postgres, use a migration tool or export CSV from SQLite and import in Supabase SQL Editor.

# --- Supabase (Dashboard → Project Settings → API) ---
NEXT_PUBLIC_SUPABASE_URL="https://your-project-ref.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="your-supabase-anon-key"
SUPABASE_SERVICE_ROLE_KEY="your-supabase-service-role-key"

# Cron (GET /api/cron/sweep-overdue with header x-cron-secret). Generate: openssl rand -hex 32
CRON_SECRET=

# Excel import row cap (optional; default 1000, capped in code)
EXCEL_MAX_ROWS=1000

# --- Railway / Render / Docker ---
# Set the same variables in the host dashboard (do not rely on committing .env).
# DATABASE_URL must be PostgreSQL — never file:... on cloud hosts (will error "Unable to open the database file").
#
# On Railway, if the database has no users yet, `npm start` runs a one-time demo bootstrap (same data as prisma/seed).
# To disable that (e.g. production with manual users only): LEADFLOW_SKIP_AUTO_BOOTSTRAP=true
