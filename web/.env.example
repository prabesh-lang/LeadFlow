# Copy to `.env` in this folder (`web/`).
#
# Primary database is PostgreSQL (Supabase). Create a project at https://supabase.com,
# then Project Settings → Database → copy the connection string (URI).
# Prefer direct connection (port 5432) or session pooler; the app uses `pg` with DATABASE_URL.
# Transaction pooler (port 6543) often works for runtime.

# --- Database (Supabase Postgres — used by `pg` and optional SQL tools) ---
# Append ?sslmode=require (Supabase expects SSL). Example:
# DATABASE_URL="postgresql://postgres.[PASSWORD]@db.[REF].supabase.co:5432/postgres?sslmode=require"
DATABASE_URL="postgresql://postgres.[YOUR-PASSWORD]@db.[YOUR-PROJECT-REF].supabase.co:5432/postgres?sslmode=require"
#
# Apply schema from `database/migrations/` via Supabase SQL Editor or `psql` when setting up a new project.
#
# If your laptop cannot reach the DB (firewall, paused project), resume Supabase or try another network.

# --- Supabase Auth (Dashboard → Project Settings → API) ---
NEXT_PUBLIC_SUPABASE_URL="https://your-project-ref.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="your-supabase-anon-key"
SUPABASE_SERVICE_ROLE_KEY="your-supabase-service-role-key"

# Cron (GET /api/cron/sweep-overdue with header x-cron-secret). Generate: openssl rand -hex 32
CRON_SECRET=

# Excel import row cap (optional; default 1000, capped in code)
EXCEL_MAX_ROWS=1000

# --- Railway / Render / Docker ---
# Set the same variables in the host dashboard (do not rely on committing .env).
# DATABASE_URL must be PostgreSQL — never file:... on cloud hosts.
#
# On Railway, if the database has no users yet, `npm start` can run a one-time bootstrap: superadmin@demo.local (password password123). Full demo data: `npm run db:seed` from the `web/` folder.
# To disable auto-bootstrap: LEADFLOW_SKIP_AUTO_BOOTSTRAP=true
