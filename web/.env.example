# Copy to `.env` in this folder (`web/`).
#
# Primary database is PostgreSQL (Supabase). Create a project at https://supabase.com,
# then Project Settings → Database → copy the connection string (URI).
# Prefer the "Session mode" or direct connection (port 5432) for Prisma migrate deploy.
# Transaction pooler (port 6543) can work for the app runtime; if migrations fail, use 5432 for DATABASE_URL during deploy.

# --- Database (Prisma → Supabase Postgres) ---
DATABASE_URL="postgresql://postgres.[YOUR-PASSWORD]@db.[YOUR-PROJECT-REF].supabase.co:5432/postgres"
#
# After changing from SQLite: run `npx prisma migrate deploy` in `web/`, then `npx prisma db seed` if you want demo data.
# To move old SQLite rows into Postgres, use a migration tool or export CSV from SQLite and import in Supabase SQL Editor.

# --- Supabase (Dashboard → Project Settings → API) ---
NEXT_PUBLIC_SUPABASE_URL="https://your-project-ref.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="your-supabase-anon-key"
SUPABASE_SERVICE_ROLE_KEY="your-supabase-service-role-key"

# Cron (GET /api/cron/sweep-overdue with header x-cron-secret). Generate: openssl rand -hex 32
CRON_SECRET=

# Excel import row cap (optional; default 1000, capped in code)
EXCEL_MAX_ROWS=1000
